    // Theme integration included
}
Icon System
Chi uses Material Symbols Rounded font. Icons can be referenced by:

Ligature name: "home", "settings", "search"
Image path: "qrc:/icons/home.svg", "/path/to/icon.png"
Common icons:

Navigation: menu, arrow_back, arrow_forward, close, expand_more, chevron_right
Actions: add, edit, delete, save, share, download, upload
Media: play_arrow, pause, stop, skip_next, skip_previous
Communication: mail, chat, notifications, send
Files: folder, description, attachment, cloud
User: person, account_circle, settings, logout
Usage Patterns
Basic App Structure
qml

import QtQuick
import Chi 1.0

ChiApplicationWindow {
    visible: true
    width: 1200
    height: 800
    title: "My App"
    
    TopAppBar {
        id: appBar
        title: "My App"
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
    }
    
    NavigationRail {
        id: navRail
        anchors.left: parent.left
        anchors.top: appBar.bottom
        anchors.bottom: parent.bottom
        
        items: ListModel {
            ListElement { icon: "home"; label: "Home" }
            ListElement { icon: "settings"; label: "Settings" }
        }
    }
    
    Item {
        anchors.left: navRail.right
        anchors.top: appBar.bottom
        anchors.right: parent.right
        anchors.bottom: parent.bottom
        
        // Page content
    }
}
Theme Toggle
qml

IconButton {
    icon: ChiTheme.isDarkMode ? "light_mode" : "dark_mode"
    onClicked: ChiTheme.toggleDarkMode()
}
Form Example
qml

Card {
    Column {
        spacing: 16
        
        TextField {
            width: parent.width
            label: "Email"
            placeholderText: "your@email.com"
            leadingIcon: "mail"
        }
        
        TextField {
            width: parent.width
            label: "Password"
            password: true
            showPasswordToggle: true
            leadingIcon: "lock"
        }
        
        Button {
            text: "Sign In"
            variant: "filled"
            onClicked: submit()
        }
    }
}
List with Actions
qml

Column {
    Repeater {
        model: itemsModel
        
        ListItem {
            width: parent.width
            text: model.name
            secondaryText: model.description
            leadingIcon: model.icon
            trailingIcon: "chevron_right"
            onClicked: openItem(model.index)
        }
    }
}
