6.1.2 Privacy Model
NEVER send terminal content to cloud without explicit user action
Each "send to AI" action shows exactly what will be sent
Local models (Ollama) work fully offline — first-class support
Cloud API keys stored in system keyring (libsecret on Linux)
No Chi Terminal account required, ever
6.1.3 AI Backend Interface
C++

// AiBackend.h
class AiBackend : public QObject {
    Q_OBJECT
public:
    virtual void sendMessage(const QString &message,
                              const QString &terminalContext = "") = 0;
    virtual void cancel() = 0;
    virtual bool isAvailable() const = 0;
    virtual QString name() const = 0;

signals:
    void responseChunk(const QString &text);    // streaming
    void responseComplete(const QString &fullText);
    void errorOccurred(const QString &error);
};

// Implementations:
class OllamaBackend : public AiBackend { /* HTTP to localhost:11434 */ };
class OpenAiBackend : public AiBackend { /* HTTPS to api.openai.com */ };
class AnthropicBackend : public AiBackend { /* HTTPS to api.anthropic.com */ };
