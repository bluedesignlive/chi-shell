4.7 Context Menu
4.7.1 Context-Aware Menu System
C++

// ContextMenuBuilder.h
class ContextMenuBuilder {
public:
    enum Context {
        Empty, SelectedText, Hyperlink,
        FilePath, IpAddress, ErrorText
    };

    Context detectContext(const QPoint &pos,
                          const TerminalSession &session);
    QVariantList buildMenuItems(Context ctx,
                                 const QString &text);
};
Detected Context	Menu Items
Empty area	Paste, Select All, Clear, ─, Split →, Split ↓, ─, New Tab
Selected text	Copy, ─, Search Web, ─, Paste, Select All
URL/Hyperlink	Open Link, Copy URL, ─, Copy, Paste
File path	Open File, Open in File Manager, Copy Path, ─, Copy, Paste
IP / hostname	Copy, ─, Paste
qml

// TerminalContextMenu.qml
ContextMenu {
    id: contextMenu

    Repeater {
        model: contextMenuBuilder.items
        delegate: Loader {
            sourceComponent: modelData.divider
                ? menuDividerComponent
                : menuItemComponent
        }
    }

    Component {
        id: menuItemComponent
        MenuItem {
            text: modelData.text
            leadingIcon: modelData.icon
            trailingText: modelData.shortcut
            enabled: modelData.enabled
            onClicked: modelData.action()
        }
    }

    Component {
        id: menuDividerComponent
        MenuDivider {}
    }
}
