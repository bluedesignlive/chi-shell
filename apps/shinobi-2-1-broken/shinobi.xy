4.5.2 QML Structure
qml

// SearchOverlay.qml
Card {
    variant: "elevated"
    width: 360
    anchors.top: parent.top
    anchors.right: parent.right
    anchors.margins: 8

    Row {
        spacing: 8

        TextField {
            id: searchField
            variant: "outlined"
            size: "small"
            placeholderText: "Search..."
            leadingIcon: "search"
            width: 240
            onAccepted: searchEngine.findNext()
        }

        // Match counter
        Text {
            text: searchEngine.currentMatch + "/" + searchEngine.totalMatches
            font: ChiTheme.typography.labelMedium
            color: ChiTheme.colors.onSurfaceVariant
        }

        IconButton { icon: "expand_less"; size: "xsmall"
                     onClicked: searchEngine.findPrevious() }
        IconButton { icon: "expand_more"; size: "xsmall"
                     onClicked: searchEngine.findNext() }

        // Toggles
        ToggleButton { text: "Aa"; size: "xsmall"
                       checked: searchEngine.caseSensitive }
        ToggleButton { text: ".*"; size: "xsmall"
                       checked: searchEngine.useRegex }

        IconButton { icon: "close"; size: "xsmall"
                     onClicked: searchOverlay.close() }
    }
}
