8. Build System
8.1 CMake Configuration
cmake

cmake_minimum_required(VERSION 3.19)
project(chi-terminal VERSION 0.1.0 LANGUAGES CXX C)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_AUTOMOC ON)

# ── Options ──────────────────────────────────────────
option(CHITERM_USE_GHOSTTY "Use libghostty-vt (requires Zig)" ON)
option(CHITERM_USE_LIBVTERM "Use libvterm as VT backend" OFF)
option(CHITERM_ENABLE_AI "Build AI assistant features" OFF)
option(CHITERM_ENABLE_TESTS "Build tests" ON)

# ── Qt ───────────────────────────────────────────────
find_package(Qt6 REQUIRED COMPONENTS
    Core Gui Quick QuickControls2 DBus Network ShaderTools
)

# ── Chi UI Library ───────────────────────────────────
# Assumes Chi is installed or available via QML import path
# set(QML_IMPORT_PATH "${CMAKE_SOURCE_DIR}/../Chi/qml" CACHE STRING "")

# ── Terminal backend ─────────────────────────────────
if(CHITERM_USE_GHOSTTY)
    # Build libghostty-vt via Zig
    include(FetchContent)
    FetchContent_Declare(ghostty
        GIT_REPOSITORY https://github.com/ghostty-org/ghostty.git
        GIT_TAG        main
        GIT_SHALLOW    TRUE
    )
    # Custom build step to invoke zig build for the C static lib
    # ...
endif()

if(CHITERM_USE_LIBVTERM)
    find_package(PkgConfig REQUIRED)
    pkg_check_modules(VTERM REQUIRED vterm)
    # or FetchContent from source
endif()

# ── toml++ ───────────────────────────────────────────
add_subdirectory(third_party/tomlplusplus EXCLUDE_FROM_ALL)

# ── Main target ──────────────────────────────────────
add_executable(chiterm
    src/main.cpp
    # ... all sources
)

target_link_libraries(chiterm PRIVATE
    Qt6::Core Qt6::Gui Qt6::Quick Qt6::QuickControls2
    Qt6::DBus Qt6::Network Qt6::ShaderTools
    tomlplusplus::tomlplusplus
    ${VTERM_LIBRARIES}      # if using libvterm
    # ghostty-vt            # if using libghostty
)
